# CIVICTAS — environment configuration
# Copy this file to .env and add a key. EVERY value is optional: with
# none set, the app runs in zero-config DEMO mode (canned, scenario-tuned
# outputs) so a fresh clone or public deploy always shows a full pipeline.
#
# Keys are read SERVER-SIDE only and are never sent to the browser.

# --- AI provider ---
# Resolution order: GEMINI_API_KEY > GROQ_API_KEY > mock. Force with LLM_PROVIDER.

# Google Gemini — free tier: https://aistudio.google.com/apikey
# Enables real-time Google Search grounding on the Evidence agent (step 2).
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-3.5-flash"

# Groq — free, fast: https://console.groq.com/keys
# Real LLM reasoning; no live web grounding (Evidence uses labeled benchmarks).
GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"

# Force a provider explicitly: gemini | groq | mock
# LLM_PROVIDER="mock"

# --- Optional hardening / integrations ---
# If set, /api/agent/* requires header  x-civictas-key: <value>
# API_SHARED_SECRET=""

# Reviewer webhook for the notify step (Slack/Telegram/etc). Simulated if unset.
# NOTIFY_WEBHOOK=""

# Open-source models via an OpenAI-compatible provider (OpenRouter by default).
# Activates when set; resolution order is GEMINI > GROQ > OPENROUTER > mock,
# or force with LLM_PROVIDER="openrouter".
# OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"   # or Together/Fireworks/local
